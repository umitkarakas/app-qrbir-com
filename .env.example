# Veritabanı
# PostgreSQL bağlantı dizesi
DATABASE_URL=postgresql://user:password@localhost:5432/qrbir

# Auth
# Uygulamanın tam URL'i (auth cookie domain ve trustedOrigins için)
BETTER_AUTH_URL=https://app.qrbir.com

# Uygulama URL'i (public linkler, e-posta içindeki linkler)
NEXT_PUBLIC_APP_URL=https://app.qrbir.com

# E-posta (Resend)
# https://resend.com adresinden API key alın
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Gönderici adresi (Resend doğrulamalı domain üzerinden)
MAIL_FROM=noreply@qrbir.com

# Admin Güvenliği
# Admin paneline erişim yetkisi verilecek e-posta adresleri (virgülle ayrılmış)
ADMIN_EMAILS=admin@qrbir.com,support@qrbir.com

# WooCommerce Entegrasyonu
# WooCommerce mağazasının tam URL'i
WC_STORE_URL=https://qrbir.com
# WooCommerce webhook imza doğrulama secret'ı (WooCommerce > Ayarlar > Gelişmiş > Webhook)
WC_WEBHOOK_SECRET=your-woocommerce-webhook-secret

# WooCommerce Fiziksel Ürün ID'leri (Sticker / Stand)
NEXT_PUBLIC_WC_DOOR_STICKER_ID=123
NEXT_PUBLIC_WC_GOOGLE_STICKER_ID=124
NEXT_PUBLIC_WC_TABLE_STICKER_ID=125

# Cron Job Güvenliği
# GET /api/cron/cleanup?secret=... endpoint'ini korur
CRON_SECRET=your-random-cron-secret
